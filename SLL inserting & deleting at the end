#include<stdio.h>
#include<stdlib.h>

struct Node{
    int data;
    struct Node *next;
};
struct Node *start=NULL;

void insert_end(){
    struct Node *newnode,*temp;
    newnode=(struct Node*)malloc(sizeof(struct Node));
    printf("enter:\n");
    scanf("%d",&newnode->data);
    newnode->next=NULL;
    temp=start;
    if (start==NULL){
        start=newnode;
        return;
    }
    while(temp->next!=NULL){
        temp=temp->next;
    }
    temp->next=newnode;
}

void display(){
    struct Node *tem;
    if (start==NULL){
        printf("nill\n");
        return;
    }
    tem=start;
    while(tem!=NULL){
        printf("%d -> ",tem->data);
        tem=tem->next;
    }
    printf("NULL\n");
}
int main(){
    int choice;
    while(1){
    printf("1.insert\n");
    printf("2.display\n");
    scanf("%d",&choice);
    switch (choice){
        case 1:
        insert_end();
        break;
        case 2:
        display();
        break;
    }
}
}
