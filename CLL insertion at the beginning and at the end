void insert_begin() {

    struct Node *newnode, *last;

    newnode = (struct Node*)malloc(sizeof(struct Node));

    if(newnode == NULL){
        printf("Overflow\n");
        return;
    }

    printf("Enter data:\n");
    scanf("%d", &newnode->data);

    // Empty list
    if(start == NULL){
        start = newnode;
        newnode->next = start;
        return;
    }

    last = start;

    while(last->next != start){
        last = last->next;
    }

    newnode->next = start;
    last->next = newnode;
    start = newnode;
}

